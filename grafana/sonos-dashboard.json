{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Sonos",
  "uid": "sonos-exporter",
  "tags": [
    "sonos",
    "prometheus",
    "audio"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data source",
        "current": {},
        "hide": 0
      },
      {
        "name": "zone",
        "type": "query",
        "label": "Speaker",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(sonos_speaker_info, zone_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Speakers reachable",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(sonos_speaker_reachable) or vector(0)",
          "instant": true,
          "range": false,
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Speakers discovered",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_speakers_discovered",
          "instant": true,
          "range": false,
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 18,
      "type": "table",
      "title": "Audio source",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 10,
        "y": 4,
        "w": 5,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_music_source{zone_name=~\"$zone\"} == 1",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "uid": true
            },
            "indexByName": {
              "zone_name": 0,
              "source": 1
            },
            "renameByName": {
              "zone_name": "Speaker",
              "source": "Source"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Playing now",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(sonos_playback_state{state=\"PLAYING\"}) or vector(0)",
          "instant": true,
          "range": false,
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Poll errors (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(sonos_poll_errors_total[1h])) + sum(increase(sonos_discovery_errors_total[1h])) or vector(0)",
          "instant": true,
          "range": false,
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Now playing",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 10,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_track_info{zone_name=~\"$zone\"} == 1",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "uid": true
            },
            "indexByName": {
              "zone_name": 0,
              "title": 1,
              "artist": 2,
              "album": 3
            },
            "renameByName": {
              "zone_name": "Speaker",
              "title": "Title",
              "artist": "Artist",
              "album": "Album"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Track progress",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 15,
        "y": 4,
        "w": 9,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sonos_track_position_seconds{zone_name=~\"$zone\"} / sonos_track_duration_seconds{zone_name=~\"$zone\"} and sonos_track_duration_seconds{zone_name=~\"$zone\"} > 0",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "legendFormat": "{{zone_name}}"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "state-timeline",
      "title": "Playback state",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "3 * sum by (zone_name) (sonos_playback_state{zone_name=~\"$zone\", state=\"PLAYING\"}) + 2 * sum by (zone_name) (sonos_playback_state{zone_name=~\"$zone\", state=\"PAUSED_PLAYBACK\"}) + sum by (zone_name) (sonos_playback_state{zone_name=~\"$zone\", state=\"TRANSITIONING\"})",
          "editorMode": "code",
          "legendFormat": "{{zone_name}}",
          "instant": false,
          "range": true
        }
      ],
      "options": {
        "showValue": "auto",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 0
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Stopped",
                  "color": "text",
                  "index": 0
                },
                "1": {
                  "text": "Transitioning",
                  "color": "blue",
                  "index": 1
                },
                "2": {
                  "text": "Paused",
                  "color": "yellow",
                  "index": 2
                },
                "3": {
                  "text": "Playing",
                  "color": "green",
                  "index": 3
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Volume",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_volume{zone_name=~\"$zone\"}",
          "editorMode": "code",
          "legendFormat": "{{zone_name}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "state-timeline",
      "title": "Muted",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_mute{zone_name=~\"$zone\"}",
          "editorMode": "code",
          "legendFormat": "{{zone_name}}",
          "instant": false,
          "range": true
        }
      ],
      "options": {
        "showValue": "never",
        "rowHeight": 0.9
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 0
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "On",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Muted",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Battery (portable speakers)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_battery_percent{zone_name=~\"$zone\"}",
          "editorMode": "code",
          "legendFormat": "{{zone_name}}",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "expr": "100 * sonos_battery_charging{zone_name=~\"$zone\"}",
          "editorMode": "code",
          "legendFormat": "{{zone_name}} charging",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* charging"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    4,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          }
        ]
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Groups",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_group_size{zone_name=~\"$zone\"}",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        },
        {
          "refId": "B",
          "expr": "sonos_group_coordinator{zone_name=~\"$zone\"}",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "zone_name",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "instance 1": true,
              "instance 2": true,
              "job 1": true,
              "job 2": true,
              "uid 1": true,
              "uid 2": true
            },
            "renameByName": {
              "zone_name": "Speaker",
              "Value #A": "Group size",
              "Value #B": "Coordinator"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Coordinator"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "member",
                        "index": 0
                      },
                      "1": {
                        "text": "coordinator",
                        "index": 1
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "EQ (bass / treble)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_bass_level{zone_name=~\"$zone\"}",
          "editorMode": "code",
          "legendFormat": "{{zone_name}} bass",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "expr": "sonos_treble_level{zone_name=~\"$zone\"}",
          "editorMode": "code",
          "legendFormat": "{{zone_name}} treble",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": -10,
          "max": 10,
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "table",
      "title": "Sound settings",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_loudness_enabled{zone_name=~\"$zone\"}",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        },
        {
          "refId": "B",
          "expr": "sonos_shuffle_enabled{zone_name=~\"$zone\"}",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        },
        {
          "refId": "C",
          "expr": "sonos_night_mode_enabled{zone_name=~\"$zone\"}",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        },
        {
          "refId": "D",
          "expr": "sonos_dialog_mode_enabled{zone_name=~\"$zone\"}",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        },
        {
          "refId": "E",
          "expr": "sum by (zone_name) (sonos_repeat_state{zone_name=~\"$zone\", mode=\"one\"} + 2 * sonos_repeat_state{zone_name=~\"$zone\", mode=\"all\"})",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "zone_name",
            "mode": "outer"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "zone_name|Value.*"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "zone_name": "Speaker",
              "Value #A": "Loudness",
              "Value #B": "Shuffle",
              "Value #C": "Night mode",
              "Value #D": "Speech enhance",
              "Value #E": "Repeat"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "off",
                  "index": 0
                },
                "1": {
                  "text": "on",
                  "index": 1
                }
              }
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Repeat"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "off",
                        "index": 0
                      },
                      "1": {
                        "text": "one",
                        "index": 1
                      },
                      "2": {
                        "text": "all",
                        "index": 2
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Poll duration",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_poll_duration_seconds{zone_name=~\"$zone\"}",
          "editorMode": "code",
          "legendFormat": "{{zone_name}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Poll errors",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 8,
        "y": 44,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (zone_name, endpoint) (increase(sonos_poll_errors_total{zone_name=~\"$zone\"}[$__rate_interval]))",
          "editorMode": "code",
          "legendFormat": "{{zone_name}} {{endpoint}}",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Time since last good poll",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 16,
        "y": 44,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - sonos_last_successful_poll_timestamp_seconds{zone_name=~\"$zone\"}",
          "instant": true,
          "range": false,
          "editorMode": "code",
          "legendFormat": "{{zone_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 120
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 17,
      "type": "table",
      "title": "Speakers",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 51,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sonos_speaker_info{zone_name=~\"$zone\"}",
