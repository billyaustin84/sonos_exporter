# sonos-exporter configuration — everything is optional.
#
# Install as /etc/sonos-exporter/sonos-exporter.env:
#   sudo install -d /etc/sonos-exporter
#   sudo install -m 644 sonos-exporter.env.example \
#        /etc/sonos-exporter/sonos-exporter.env

# Comma-separated speaker IPs. If unset, speakers are found with SSDP
# multicast discovery — set this when the exporter runs on a different
# VLAN/subnet than the speakers, in Docker's default network, or in WSL,
# where multicast doesn't reach them.
#SONOS_HOSTS=192.168.1.50,192.168.1.51

# -- Optional (defaults shown) --
#EXPORTER_PORT=9805
#EXPORTER_ADDRESS=0.0.0.0
#POLL_INTERVAL_SECONDS=30
#DISCOVERY_INTERVAL_SECONDS=300
#DISCOVERY_TIMEOUT_SECONDS=5

# The currently playing track is exported as a labelled series
# (sonos_track_info{title=...,artist=...,album=...}). Every track change
# creates a new series; disable if that cardinality bothers your Prometheus.
#EXPORT_TRACK_INFO=true

#LOG_LEVEL=INFO
